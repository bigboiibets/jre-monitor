# ============================================================
# JRE Monitor — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED -----------------------------------------------

# Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (send a message to @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# JRE YouTube channel ID
# How to find it: go to https://www.youtube.com/@joerogan
# View page source (Ctrl+U), search for "channelId"
# It looks like: UCzWQYUVCpZqtN93H8RR44Qw
JRE_YOUTUBE_CHANNEL_ID=

# ---- OPTIONAL (defaults shown) ------------------------------

# JRE podcast RSS feed (Megaphone). Leave blank to disable podcast RSS detection.
JRE_PODCAST_RSS_URL=https://feeds.megaphone.fm/GLT1412515089

# How often to poll detection sources (seconds)
POLL_INTERVAL_SECONDS=30

# Whisper model size: tiny.en | base.en | small.en
# tiny.en = fastest, least accurate
# base.en = good balance (default)
# small.en = most accurate, slower
WHISPER_MODEL=base.en

# Audio chunk duration in seconds (smaller = lower latency, more overhead)
CHUNK_SECONDS=25

# Path to ffmpeg. If ffmpeg is on your PATH, leave as "ffmpeg".
# If you placed ffmpeg.exe in the project directory: FFMPEG_PATH=ffmpeg.exe
FFMPEG_PATH=ffmpeg

# Suppress re-alerts for the same keyword within this window (minutes)
DEDUP_WINDOW_MINUTES=10

# SQLite database file
DB_PATH=jre_monitor.db

# Set to true to log alerts without sending to Telegram (for testing)
DRY_RUN=false

# Logging level: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
